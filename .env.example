# WheelBoard API Keys - Example
# Copy this file to .env and fill in your actual values
# WARNING: Never commit .env file to version control!

# Razorpay Keys (Get from https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Google Maps API Key (Get from https://console.cloud.google.com)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# WheelBoard Company Logo URL (for Razorpay checkout)
COMPANY_LOGO_URL=https://your-domain.com/images/logo.png
